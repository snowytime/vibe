	"license": "ISC",
	"type": "module",
	"engines": {
		"node": ">=16.0.0"
	},
	"bin": {
		"vibe": "./dist/cli/main.js"
	},
	"files": [
		"dist",
		"app"
	],
	"main": "dist/index.js",
	"module": "dist/index.js",
