{
    "name": "@snowytime/vibe",
    "version": "0.0.113",
    "author": "snowytime",
    "license": "ISC",
    "type": "module",
    "engines": {
        "node": ">=16.0.0"
    },
    "bin": {
        "vibe": "./dist/cli/main.js"
    },
    "files": [
        "dist",
        "app"
    ],
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./client": "./dist/app/src/exports.js"
    },
    "typesVersions": {
        "*": {
            "client": [
                "dist/app/src/exports.d.ts"
            ]
        }
    },
    "devDependencies": {
        "@snowytime/standards": "^1.0.4",
        "@swc/cli": "^0.1.62",
        "@types/glob": "^8.1.0",
        "@types/node": "^18.14.5",
        "@types/react": "^18.0.28",
        "@types/react-dom": "^18.0.11",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "typescript": "^4.9.5"
    },
    "dependencies": {
        "@snowytime/iconly-react": "^1.0.4",
        "@snowytime/react-hooks": "^1.0.8",
        "@swc/core": "^1.3.37",
        "@vitejs/plugin-react": "^3.1.0",
        "chokidar": "^3.5.3",
        "commander": "^10.0.0",
        "esbuild": "^0.17.10",
        "express": "^4.18.2",
        "get-port": "^6.1.2",
        "glob": "^9.2.1",
        "globby": "^13.1.3",
        "nanoid": "^4.0.1",
        "picocolors": "^1.0.0",
        "react-router-dom": "^6.8.2",
        "sass": "^1.58.3",
        "vite": "^4.1.4",
        "vite-tsconfig-paths": "^4.0.5"
    },
    "peerDependencies": {
        "react": ">=16.14.0",
        "react-dom": ">=16.14.0"
    },
    "scripts": {
        "build": "rm -rf dist && swc src --config-file build.json -d dist && tsc && sh finalize.sh",
        "start": "node dist/index.js",
        "demo": "npm run build && node .test/index.js",
        "release:patch": "npm run build && git add . && git commit -m '⚡️ auto patch' && git push origin master && npm version patch && npm publish"
    },
    "imports": {
        "#errors/*": "./src/errors/*",
        "#debug/*": "./src/debug/*",
        "#logs/*": "./src/logs/*",
        "#type/*": "./src/types/*",
        "#finders/*": "./src/finders/*",
        "#config/*": "./src/config/*",
        "#helpers/*": "./src/helpers/*",
        "#structures/*": "./src/structures/*",
        "#parsers/*": "./src/parsers/*"
    }
}
