{
    "name": "@snowytime/vibe",
    "version": "0.0.81",
    "description": "The Vibe base engine",
    "keywords": [
        "vibe",
        "react"
    ],
    "author": "snowytime",
    "license": "ISC",
    "type": "module",
    "engines": {
        "node": ">=16.0.0"
    },
    "bin": {
        "vibe": "./dist/cli/main.js"
    },
    "files": [
        "dist",
        "app"
    ],
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./client": "./app/src/exports"
    },
    "typesVersions": {
        "*": {
            "client": [
                "dist/app/src/exports.d.ts"
            ]
        }
    },
    "devDependencies": {
        "@swc/cli": "^0.1.57",
        "@types/debug": "^4.1.7",
        "@types/glob": "^8.0.0",
        "@types/node": "^18.11.17",
        "@types/react": "^18.0.26",
        "@types/react-dom": "^18.0.10",
        "@typescript-eslint/eslint-plugin": "^5.48.1",
        "@typescript-eslint/parser": "^5.48.1",
        "eslint": "^8.31.0",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-prettier": "^8.6.0",
        "eslint-plugin-import": "^2.27.4",
        "eslint-plugin-jsx-a11y": "^6.7.1",
        "eslint-plugin-prettier": "^4.2.1",
        "eslint-plugin-react": "^7.32.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "prettier": "^2.8.3",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "typescript": "^4.9.4"
    },
    "dependencies": {
        "@snowytime/react-hooks": "^1.0.7",
        "@swc/core": "^1.3.23",
        "@vitejs/plugin-react": "^3.0.0",
        "chokidar": "^3.5.3",
        "commander": "^9.4.1",
        "debug": "^4.3.4",
        "esbuild": "^0.16.10",
        "express": "^4.18.2",
        "get-port": "^6.1.2",
        "glob": "^8.0.3",
        "globby": "^13.1.3",
        "nanoid": "^4.0.0",
        "picocolors": "^1.0.0",
        "react-router-dom": "^6.6.1",
        "vite": "^4.0.3",
        "vite-tsconfig-paths": "^4.0.3"
    },
    "peerDependencies": {
        "react": ">=16.14.0",
        "react-dom": ">=16.14.0"
    },
    "scripts": {
        "build": "rm -rf dist && swc src -d dist && tsc -p ./tsconfig.build.json",
        "start": "node dist/index.js",
        "demo": "npm run build && node .test/index.js",
        "release:patch": "npm run build && git add . && git commit -m '🥳 auto patch' && git push origin master && npm version patch && npm publish"
    }
}
