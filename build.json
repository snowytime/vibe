{
    "exclude": "^*.test.*$",
    "minify": true,
    "jsc": {
        "parser": {
            "syntax": "typescript",
            "tsx": true,
            "decorators": true,
            "dynamicImport": true
        },
        "target": "es2020",
        "baseUrl": ".",
        "paths": {
            "#errors/*": ["./dist/errors/*"],
            "#debug/*": ["./dist/debug/*"],
            "#logs/*": ["./dist/logs/*"],
            "#type/*": ["./dist/types/*"],
            "#finders/*": ["./dist/finders/*"],
            "#config/*": ["./dist/config/*"],
            "#helpers/*": ["./dist/helpers/*"],
            "#structures/*": ["./dist/structures/*"],
            "#parsers/*": ["./dist/ast/*"]
        }
    },
    "module": {
        "type": "nodenext"
    }
}
