{
    "jsc": {
        "parser": {
            "syntax": "typescript",
            "tsx": false,
            "decorators": true,
            "dynamicImport": true
        },
        "target": "es2020",
        "paths": {
            "@errors/*": ["./dist/errors/*"],
            "@debug/*": ["./dist/debug/*"],
            "@logs/*": ["./dist/logs/*"],
            "@type/*": ["./dist/types/*"],
            "@finders/*": ["./dist/finders/*"],
            "@config/*": ["./dist/config/*"],
            "@helpers/*": ["./dist/helpers/*"],
            "@structures/*": ["./dist/structures/*"],
            "@parsers/*": ["./dist/ast/*"]
        },
        "baseUrl": "."
    },
    "module": {
        "type": "es6"
    }
}
