{
    "compilerOptions": {
        "module": "NodeNext",
        "target": "ESNext",
        "lib": ["ESNext", "ESNext.AsyncIterable", "DOM"],
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "emitDeclarationOnly": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist",
        "resolveJsonModule": true,
        "jsx": "react",
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "virtual:vibe": ["app/src/main.d.ts"],
            "#errors/*": ["./src/errors/*"],
            "#debug/*": ["./src/debug/*"],
            "#logs/*": ["./src/logs/*"],
            "#type/*": ["./src/types/*"],
            "#finders/*": ["./src/finders/*"],
            "#config/*": ["./src/config/*"],
            "#helpers/*": ["./src/helpers/*"],
            "#structures/*": ["./src/structures/*"],
            "#parsers/*": ["./src/parsers/*"]
        },
        "rootDir": "."
    },
    "include": ["./src/**/*", "./app/**/*"],
    "ts-node": {
        "esm": true,
        "files": true,
        "transpileOnly": true,
        "experimentalSpecifierResolution": "explicit",
        "experimentalResolver": true
    }
}
