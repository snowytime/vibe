{
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2020",
		"sourceMap": true,
		"jsx": "react"
	},
	"include": ["./src/**/*"],
	"paths": {
		"@errors/*": ["./src/errors/*"],
		"@debug/*": ["./src/debug/*"],
		"@logs/*": ["./src/logs/*"],
		"@finders/*": ["./src/node/finders/*"],
		"@config/*": ["./src/node/config/*"],
		"@helpers/*": ["./src/node/helpers/*"],
		"@parsers/*": ["./src/node/ast/*"],
		"@type/*": ["./src/types/*"]
	}
}
