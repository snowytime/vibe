{
    "compilerOptions": {
        "module": "NodeNext",
        "target": "ESNext",
        "lib": ["ESNext", "ESNext.AsyncIterable", "DOM"],
        "moduleResolution": "node16",
        "esModuleInterop": true,
        "emitDeclarationOnly": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist",
        "resolveJsonModule": true,
        "jsx": "react",
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "virtual:vibe": ["app/src/main.d.ts"]
        },
        "rootDir": "."
    },
    "include": ["./src/**/*", "./app/**/*"],
    "ts-node": {
        "esm": true,
        "files": true,
        "transpileOnly": true,
        "experimentalSpecifierResolution": "explicit",
        "experimentalResolver": true
    }
}
