{
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2020",
		"sourceMap": true,
		"jsx": "react",
		"baseUrl": ".",
		"paths": {
			"@errors/*": ["./src/errors/*"],
			"@debug/*": ["./src/debug/*"],
			"@logs/*": ["./src/logs/*"],
			"@finders/*": ["./src/finders/*"],
			"@config/*": ["./src/config/*"],
			"@helpers/*": ["./src/helpers/*"],
			"@structures/*": ["./src/structures/*"],
			"@parsers/*": ["./src/ast/*"],
			"@type/*": ["./src/types/*"]
		}
	},
	"include": ["./src/**/*"],
	"exclude": ["node_modules"]
}
