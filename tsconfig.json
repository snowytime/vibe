{
    "compilerOptions": {
        "module": "NodeNext",
        "target": "ESNext",
        "lib": ["ESNext", "ESNext.AsyncIterable", "DOM"],
        "moduleResolution": "node16",
        "esModuleInterop": true,
        "emitDeclarationOnly": true,
        "declaration": true,
        "declarationMap": true,
        "declarationDir": "dist",
        "resolveJsonModule": true,
        "jsx": "react",
        "skipLibCheck": true,
        "baseUrl": "src",
        "paths": {
            "virtual-vibe": ["app/src/main.d.ts"]
        },
        "rootDir": "src"
    },
    "include": ["src/**/*", "*.d.ts"],
    "ts-node": {
        "esm": true,
        "files": true,
        "transpileOnly": true,
        "experimentalSpecifierResolution": "explicit",
        "experimentalResolver": true
    }
}
