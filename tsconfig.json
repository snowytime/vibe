{
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2020",
		"allowJs": true,
		"removeComments": true,
		"resolveJsonModule": true,
		"typeRoots": ["./node_modules/@types"],
		"sourceMap": true,
		"outDir": "dist",
		"strict": true,
		"baseUrl": ".",
		"forceConsistentCasingInFileNames": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"skipLibCheck": true,
		"paths": {
			"@errors/*": ["./src/errors/*"],
			"@debug/*": ["./src/debug/*"],
			"@logs/*": ["./src/logs/*"],
			"@finders/*": ["./src/node/finders/*"],
			"@config/*": ["./src/node/config/*"],
			"@helpers/*": ["./src/node/helpers/*"],
			"@parsers/*": ["./src/node/ast/*"],
			"@type/*": ["./src/types/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
