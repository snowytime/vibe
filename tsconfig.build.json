{
    "extends": "./tsconfig.json",
    "include": ["./src/**/*"],
    "compilerOptions": {
        "rootDir": "src",
        "allowJs": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "dist",
        "declarationMap": true,
        "skipLibCheck": true
    }
}
